{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "/home/loivang/projects/insighthub"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "@edjl/docker-mcp@1.0.7"
      ]
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@0.0.49",
        "--read-only"
      ],
      "env": {
        "KUBECONFIG": "/home/loivang/.kube/mcp-viewer.kubeconfig"
      }
    },
    "prometheus": {
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "@wkronmiller/prometheus-mcp-server@1.0.0",
        "prometheus-mcp-server"
      ],
      "env": {
        "PROMETHEUS_URL": "http://localhost:9090"
      }
    }
  }
}
