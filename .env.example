# InsightHub — biến môi trường mẫu
# Copy file này thành .env và điền giá trị thật:  cp .env.example .env
#
# ⚠️ KHÔNG commit .env lên Git (.gitignore đã chặn sẵn).
#
# Mặc định dùng Gemini (Google AI Studio) — free tier hào phóng.
# Đổi provider bằng cách sửa LLM_PROVIDER / EMBEDDING_PROVIDER, không cần sửa code.

# ============================================================
# LLM (generation)
# ============================================================
# Provider: gemini (default) | anthropic | bedrock | ollama
LLM_PROVIDER=gemini

# --- Gemini (Google AI Studio) — DEFAULT ---
# Lấy key tại https://aistudio.google.com/apikey (free tier).
# Để trống → fallback extractive (pipeline vẫn chạy nhưng không có chất lượng).
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3-flash-preview

# --- Anthropic ---
# Lấy key tại https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# --- Ollama (local, on-prem) ---
# Không cần API key. Pull model trước: `ollama pull deepseek-r1:14b`
# Khi chạy ngoài docker-compose: đổi http://ollama:11434 → http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=deepseek-r1:14b

# --- Generic LLM params (override provider-specific nếu set) ---
# LLM_MODEL=                # nếu trống → dùng <provider>_CHAT_MODEL ở trên
LLM_MAX_TOKENS=1024

# ============================================================
# Embedding
# ============================================================
# Provider: gemini (default) | voyage | openai | ollama | local
#   - gemini:   default, free tier, Matryoshka — output_dim configurable
#   - voyage:   chất lượng cao cho Claude
#   - openai:   thay thế, đổi EMBEDDING_DIM=1536 cho text-embedding-3-small
#   - ollama:   on-prem, dùng cùng model với LLM (deepseek-r1:14b)
#   - local:    hash-based KHÔNG cần key — retrieval kém, chỉ smoke test
EMBEDDING_PROVIDER=gemini

# --- Gemini embedding (DEFAULT) ---
# Ref: https://ai.google.dev/gemini-api/docs/embeddings
# Dùng cùng GEMINI_API_KEY ở trên.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# --- Voyage ---
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3.5

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama embedding (cùng URL với chat) ---
OLLAMA_EMBEDDING_MODEL=deepseek-r1:14b

# --- Generic embedding model name override (optional) ---
# EMBEDDING_MODEL=

# Vector dimension — PHẢI khớp VECTOR(n) trong infra/db/init.sql.
# Default 1024:
#   - Gemini: gửi output_dimensionality=1024 (Matryoshka truncation OK)
#   - voyage-3.5: native 1024
#   - openai text-embedding-3-small: đổi sang 1536 + rebuild schema
#   - Ollama (deepseek-r1:14b): native ~5120 → code truncate xuống 1024
EMBEDDING_DIM=1024

# ============================================================
# Infra (mặc định khớp docker-compose)
# ============================================================
DATABASE_URL=postgresql://insighthub:insighthub@postgres:5432/insighthub
REDIS_URL=redis://redis:6379

# ============================================================
# RAG tuning (optional)
# ============================================================
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# RETRIEVAL_TOP_K=5
# HNSW_EF_SEARCH=100
